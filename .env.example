# ============================================================
# Configuration — runs fully locally, no cloud account needed
# ============================================================
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env

# Local LLM via Ollama (run `ollama serve`; model must be pulled)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Model router — choose a model per query by complexity
# ============================================================
# When enabled, the planner step classifies each query SIMPLE or COMPLEX and
# routes it to the fast or strong model. Run `python -m evals.run_evals` to
# measure quality vs latency and derive the policy (evals/results/policy.json,
# which overrides these env values at runtime). Both models must be pulled:
#   ollama pull llama3.2:1b && ollama pull qwen2.5:3b
MODEL_ROUTER_ENABLED=true
ROUTER_FAST_MODEL=llama3.2:1b
ROUTER_STRONG_MODEL=qwen2.5:3b

# Local embedding model (must also be pulled via Ollama):
#   ollama pull mxbai-embed-large
# If you change the model, set EMBEDDING_DIM to match and drop the
# document_chunks table so it can be recreated with the new dimension.
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIM=1024

# Local Postgres + pgvector. Create the database first:
#   psql -U postgres -c "CREATE DATABASE financial_rag;"
#   psql -U postgres -d financial_rag -c "CREATE EXTENSION IF NOT EXISTS vector;"
# The app will create the tables on first run.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_rag

# Folder scanned on startup for documents to ingest.
# Drop PDFs / DOCX / XLSX / TXT / CSV / etc. here and restart the app
# (or click "Re-scan documents folder" in the sidebar).
DOCUMENTS_DIR=./data/documents

# ============================================================
# Retrieval pipeline toggles
# ============================================================
# Search strategy used by the retriever:
#   vector  — dense cosine only (pgvector embeddings)
#   keyword — full-text only   (Postgres BM25-style ts_rank_cd)
#   hybrid  — dense + sparse fused via Reciprocal Rank Fusion (recommended)
RETRIEVAL_MODE=hybrid

# Top-k chunks handed to the analyst. Over-fetch is used internally when
# fusing multiple legs or reranking (FETCH_K), then trimmed back to K.
RETRIEVAL_K=6
RETRIEVAL_FETCH_K=20

# Conversational rewrite — turns follow-ups like "what about Q2?" into
# standalone search queries using the chat history. Cheap (one short LLM
# call) and improves multi-turn retrieval noticeably.
RETRIEVAL_REWRITE=true

# Multi-query expansion — the planner LLM generates 3 paraphrases of the
# question; each is searched and results are RRF-fused. Off by default
# because it adds an LLM round-trip per query (slow on CPU).
RETRIEVAL_MULTI_QUERY=false

# HyDE — generate a hypothetical short answer and embed THAT instead of
# (well, alongside) the raw question. Off by default for the same reason.
RETRIEVAL_HYDE=false

# Cross-encoder rerank done by the planner LLM. After retrieval, the LLM
# scores each candidate chunk 0–10 and the top RETRIEVAL_K are kept. Most
# expensive option: one large prompt per query. Off by default.
RETRIEVAL_RERANK=false

# ============================================================
# LangSmith tracing (optional, OFF by default)
# ============================================================
# Observability for every LLM call and agent run (planner → retriever →
# analyst, plus question suggestions). This is the ONE part of this app that
# talks to the cloud (smith.langchain.com), so it stays off until you opt in.
#
# To enable:
#   1. Create a free account at https://smith.langchain.com
#   2. Make an API key:  Settings → API Keys  (starts with "lsv2_")
#   3. Set LANGSMITH_TRACING=true and paste the key below, then restart.
# Traces then appear under the project name set here. No other code changes
# are needed — LangChain auto-instruments the calls.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-agentic-platform
# Default US endpoint. Use https://eu.api.smith.langchain.com for the EU region
# or your self-hosted URL.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
