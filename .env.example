# ============================================================
# Configuration — runs fully locally, no cloud account needed
# ============================================================
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env

# Local LLM via Ollama (run `ollama serve`; model must be pulled)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Model router — choose a model per query by complexity
# ============================================================
# When enabled, the planner step classifies each query SIMPLE or COMPLEX and
# routes it to the fast or strong model. Run `python -m evals.run_evals` to
# measure quality vs latency and derive the policy (evals/results/policy.json,
# which overrides these env values at runtime). Both models must be pulled:
#   ollama pull llama3.2:1b && ollama pull qwen2.5:3b
MODEL_ROUTER_ENABLED=true
ROUTER_FAST_MODEL=llama3.2:1b
ROUTER_STRONG_MODEL=qwen2.5:3b

# Local embedding model (must also be pulled via Ollama):
#   ollama pull mxbai-embed-large
# If you change the model, set EMBEDDING_DIM to match and drop the
# document_chunks table so it can be recreated with the new dimension.
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIM=1024

# Local Postgres + pgvector. Create the database first:
#   psql -U postgres -c "CREATE DATABASE financial_rag;"
#   psql -U postgres -d financial_rag -c "CREATE EXTENSION IF NOT EXISTS vector;"
# The app will create the tables on first run.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_rag

# Connection pool (psycopg-pool). Reuses warm connections instead of opening a
# fresh TCP+auth connection per query. Falls back to direct connections if
# psycopg-pool isn't installed or DB_POOL_ENABLED=false.
DB_POOL_ENABLED=true
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_MAX_IDLE=300

# ============================================================
# Semantic response cache
# ============================================================
# Returns a previously generated answer when the same — or a sufficiently
# similar — question is asked again, skipping the expensive LLM generation.
# Exact repeats are O(1); near-duplicates match by query-embedding cosine
# similarity >= the threshold. Cached answers are scoped to (model, corpus
# size), so they self-invalidate when you switch models or change the indexed
# documents. Only standalone questions are cached (follow-ups that depend on
# chat history, and filtered searches, are not).
RESPONSE_CACHE_ENABLED=true
# Cosine similarity required for a semantic (non-exact) hit. High on purpose:
# in finance, "CPR for pool A" vs "pool B" embed closely and a wrong hit is
# worse than a miss. Lower toward ~0.93 for more aggressive caching.
RESPONSE_CACHE_THRESHOLD=0.97
# Max cached answers (LRU eviction beyond this).
RESPONSE_CACHE_MAX=256
# Seconds before an entry expires. 0 = never expire.
RESPONSE_CACHE_TTL=0

# Folder scanned on startup for documents to ingest.
# Drop PDFs / DOCX / XLSX / TXT / CSV / etc. here and restart the app
# (or click "Re-scan documents folder" in the sidebar).
DOCUMENTS_DIR=./data/documents

# ============================================================
# Retrieval pipeline toggles
# ============================================================
# Search strategy used by the retriever:
#   vector  — dense cosine only (pgvector embeddings)
#   keyword — full-text only   (Postgres BM25-style ts_rank_cd)
#   hybrid  — dense + sparse fused via Reciprocal Rank Fusion (recommended)
RETRIEVAL_MODE=hybrid

# Top-k chunks handed to the analyst. Over-fetch is used internally when
# fusing multiple legs or reranking (FETCH_K), then trimmed back to K.
RETRIEVAL_K=6
RETRIEVAL_FETCH_K=20

# Conversational rewrite — turns follow-ups like "what about Q2?" into
# standalone search queries using the chat history. Cheap (one short LLM
# call) and improves multi-turn retrieval noticeably.
RETRIEVAL_REWRITE=true

# Multi-query expansion — the planner LLM generates 3 paraphrases of the
# question; each is searched and results are RRF-fused. Off by default
# because it adds an LLM round-trip per query (slow on CPU).
RETRIEVAL_MULTI_QUERY=false

# HyDE — generate a hypothetical short answer and embed THAT instead of
# (well, alongside) the raw question. Off by default for the same reason.
RETRIEVAL_HYDE=false

# Cross-encoder rerank done by the planner LLM. After retrieval, the LLM
# scores each candidate chunk 0–10 and the top RETRIEVAL_K are kept. Most
# expensive option: one large prompt per query. Off by default.
RETRIEVAL_RERANK=false

# ============================================================
# Guardrails & PII protection (security layer, ON by default)
# ============================================================
# A local, dependency-free security layer enforced at three boundaries:
#   • input   — user query: length cap + prompt-injection detection
#   • context — retrieved chunks: indirect-injection neutralization + PII mask
#   • output  — model answer: PII redaction before display / storage / trace
# See src/guardrails/ and the OWASP-LLM mapping in
# .github/skills/security-auditor/references/owasp-llm-top-10.md
GUARDRAILS_ENABLED=true

# Reject any single user message longer than this (unbounded-consumption guard).
GUARDRAILS_MAX_INPUT_CHARS=8000

# What to do when a prompt-injection / jailbreak attempt is detected in the
# user's query: "flag" (annotate the trace, still answer) or "block" (refuse).
GUARDRAILS_INJECTION_ACTION=flag

# --- PII (SSN, bank account, ABA routing, credit card, IBAN, EIN, email,
#         phone, IP) ---
GUARDRAILS_PII_ENABLED=true

# Masking strategy applied when PII is redacted:
#   partial — keep last 4, mask the rest (e.g. •••-••-1234)   [default]
#   label   — replace with a tag (e.g. [REDACTED_SSN])
#   hash    — replace with a stable [SSN:1a2b3c4d5e] token
#   remove  — replace with a bare [SSN] marker
GUARDRAILS_PII_STRATEGY=partial

# Restrict to specific detectors (comma-separated names) or "all".
# Names: US_SSN, US_EIN, CREDIT_CARD, IBAN, ABA_ROUTING, BANK_ACCOUNT,
#        EMAIL, PHONE, IP_ADDRESS
GUARDRAILS_PII_TYPES=all

# Where PII is acted on. Output + logging + context masking + prompt redaction
# default ON so PII never reaches the user, the logs, the models, or LangSmith.
# Ingestion redaction defaults OFF (PII is still detected and recorded in chunk
# metadata) so retrieval quality isn't silently degraded — flip it on for the
# strongest data-at-rest posture (raw PII never written to pgvector).
GUARDRAILS_PII_REDACT_OUTPUT=true
GUARDRAILS_PII_REDACT_INPUT=true
GUARDRAILS_PII_SCAN_CONTEXT=true
GUARDRAILS_PII_REDACT_ON_INGEST=false

# Redact PII from the query + chat history BEFORE any model call. With this on
# (default), the planner/analyst/rewrite never see raw PII and nothing raw is
# sent to an off-machine trace (LangSmith). Set false if you need the model to
# operate on the user's raw PII (it will then also appear in traces).
GUARDRAILS_PII_REDACT_PROMPTS=true

# Streaming output redaction hold-back window (chars). The live token stream is
# masked too (not just the final answer); this many trailing chars are buffered
# so a number split across tokens is never shown before it can be redacted.
# Must exceed the longest PII match (IBAN ≈ 34, card ≈ 23). 64 is safe.
GUARDRAILS_STREAM_HOLD_CHARS=64

# ============================================================
# LangSmith tracing (optional, OFF by default)
# ============================================================
# Observability for every LLM call and agent run (planner → retriever →
# analyst, plus question suggestions). This is the ONE part of this app that
# talks to the cloud (smith.langchain.com), so it stays off until you opt in.
#
# To enable:
#   1. Create a free account at https://smith.langchain.com
#   2. Make an API key:  Settings → API Keys  (starts with "lsv2_")
#   3. Set LANGSMITH_TRACING=true and paste the key below, then restart.
# Traces then appear under the project name set here. No other code changes
# are needed — LangChain auto-instruments the calls.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-agentic-platform
# Default US endpoint. Use https://eu.api.smith.langchain.com for the EU region
# or your self-hosted URL.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
